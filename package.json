{
  "name": "testglance-action",
  "version": "0.1.0",
  "private": true,
  "description": "TestGlance GitHub Action - Track test suite health over time",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts --out dist --source-map --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "fast-xml-parser": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.19",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.0.7"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
