{
  "name": "testglance-action",
  "version": "0.1.0",
  "private": true,
  "description": "TestGlance GitHub Action - Track test suite health over time",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "ncc build src/index.ts --out dist --source-map --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "postinstall": "node scripts/patch-esm-exports.cjs"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,mjs,js,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@actions/artifact": "^6.2.1",
    "@actions/cache": "^4.1.0",
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "fast-glob": "^3.3.3",
    "fast-xml-parser": "^5.5.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.4.4",
    "@types/node": "^25.5.2",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
